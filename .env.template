# -------------------------------------------------------------------------
# [트위터(X) API 자격 증명 - OAuth 1.0 기준]
# developer.x.com 사이트에서 프로젝트 및 앱 생성 후 발급받은 키 입력
# -------------------------------------------------------------------------
X_CONSUMER_KEY=your_consumer_key_here
X_CONSUMER_SECRET=your_consumer_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_SECRET=your_access_token_secret_here
X_BEARER_TOKEN=your_bearer_token_here

# -------------------------------------------------------------------------
# [Gemini AI API 자격 증명]
# aistudio.google.com 사이트에서 발급받은 키 입력
# -------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -------------------------------------------------------------------------
# [제휴 마케팅 설정 - 전면 재점검 버전]
# -------------------------------------------------------------------------
# 1. 쿠팡 파트너스 (partners.coupang.com)
COUPANG_ACCESS_KEY=your_access_key
COUPANG_SECRET_KEY=your_secret_key
COUPANG_AF_ID=AF1234567

# 2. 알리익스프레스 어필리에이트 (portals.aliexpress.com)
# API 연동을 통한 딥링크 생성이 필요한 경우 발급받으세요.
ALI_APP_KEY=your_ali_app_key
ALI_APP_SECRET=your_ali_app_secret
ALI_TRACKING_ID=your_ali_tracking_id

# 3. 아마존 어소시에이트 (affiliate-program.amazon.com)
# PA API(Product Advertising API) 사용 시 필요합니다.
AMAZON_ACCESS_KEY=your_amazon_access_key
AMAZON_SECRET_KEY=your_amazon_secret_key
AMAZON_TAG=your_amazon_tag-20

# 4. 테무 어필리에이트 (affiliate.temu.com)
TEMU_APP_KEY=your_temu_app_key
TEMU_APP_SECRET=your_temu_app_secret
TEMU_TRACKING_ID=your_temu_tracking_id
TEMU_INVITE_CODE=your_temu_code

# -------------------------------------------------------------------------
# [국내 쇼핑몰 제휴 마케팅 — 알구몬 딜 87% 커버 핵심]
# -------------------------------------------------------------------------

# 5. 애드픽 (adpick.co.kr) — 11번가/G마켓/옥션/롯데온/무신사 등 통합
# 마이페이지 > API 설정 에서 발급
ADPICK_API_KEY=your_adpick_api_key_here

# 6. 텐핑 (tenping.kr) — 11번가 전용, 수수료 최대 11%
# 내 채널 > 고유링크 > tracking code 확인
TENPING_TRACKING_CODE=your_tenping_code

# 7. 링크프라이스 (linkprice.com) — 프리미엄 제휴 네트워크
# 파트너 ID (승인 후 발급)
LINKPRICE_AFFILIATE_ID=your_linkprice_id

# -------------------------------------------------------------------------
# [텔레그램 채널 설정 - 선택사항, 수익 증폭 핵심]
# @BotFather → /newbot → 토큰 발급 후 채널 관리자로 등록
# 채널 ID: @채널명 또는 숫자형 ID (-100XXXXXXXXX)
# -------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=@your_channel_name

# -------------------------------------------------------------------------
# [봇 동작 설정]
# X API 무료 플랜 기준 일 50건 한도. 안전 마진으로 45 권장.
# -------------------------------------------------------------------------
MAX_TWEETS_PER_DAY=45
